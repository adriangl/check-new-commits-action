{
    "name": "check-new-commits",
    "version": "2.0.0",
    "description": "GitHub action that checks if there has been any new commit in a given time frame",
    "type": "module",
    "private": true,
    "homepage": "https://github.com/adriangl/check-new-commits-action",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/adriangl/check-new-commits-action.git"
    },
    "bugs": {
        "url": "https://github.com/adriangl/check-new-commits-action/issues"
    },
    "keywords": [
        "GitHub",
        "Actions",
        "TypeScript"
    ],
    "author": "Adrián García",
    "license": "MIT",
    "exports": {
        ".": "./dist/index.js"
    },
    "engines": {
        "node": ">=24.0.0"
    },
    "scripts": {
        "act": "act -j test-action --secret-file .secrets --env-file .env",
        "bundle": "npm run format:write && npm run package",
        "ci-test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest --runInBand",
        "coverage": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest --coverage",
        "format:write": "npx prettier --write .",
        "format:check": "npx prettier --check .",
        "lint": "npx eslint .",
        "local-action": "npx @github/local-action . src/index.ts .env",
        "package": "npx rimraf ./dist && npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
        "package:watch": "npm run package -- --watch",
        "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
        "all": "npm run format:write && npm run lint && npm run test && npm run package",
        "release": "standard-version",
        "postversion": "git push --follow-tags"
    },
    "standard-version": {
        "scripts": {
            "posttag": "TAG=$(git describe --tags --abbrev=0); MAJOR_TAG=${TAG%%.*}; git tag -f $MAJOR_TAG"
        }
    },
    "dependencies": {
        "@actions/core": "^3.0.0",
        "@actions/github": "^6.0.1"
    },
    "devDependencies": {
        "@eslint/compat": "^2.0.2",
        "@eslint/eslintrc": "^3.3.3",
        "@eslint/js": "^10.0.1",
        "@github/local-action": "^7.0.1",
        "@jest/globals": "^30.2.0",
        "@rollup/plugin-commonjs": "^29.0.0",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-typescript": "^12.3.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.2.3",
        "@typescript-eslint/eslint-plugin": "^8.56.0",
        "@typescript-eslint/parser": "^8.60.1",
        "eslint": "^10.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jest": "^29.15.0",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^15.12.0",
        "jest": "^30.2.0",
        "prettier": "^3.8.1",
        "rimraf": "^6.0.1",
        "rollup": "^4.57.1",
        "standard-version": "^9.5.0",
        "ts-jest": "^29.4.6",
        "ts-jest-resolver": "^2.0.1",
        "typescript": "^6.0.3"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "*"
    }
}
